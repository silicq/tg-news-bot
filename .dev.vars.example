# Copy this file to `.dev.vars` for local development (`wrangler dev`).
# `.dev.vars` is git-ignored. In production these go into the Cloudflare
# dashboard (Workers > Settings > Variables and Secrets) or via
# `wrangler secret put <NAME>`.

# --- SECRETS (never commit real values) ---

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN="123456:ABC-DEF_your_bot_token_here"

# Telegram numeric user id of the admin. Only this user can run bot commands
# (/test, /stats, /run). Find it via @userinfobot.
ADMIN_ID="123456789"

# Token that protects the manual HTTP trigger (GET /run, GET /setup) AND is used
# as the Telegram webhook secret_token. Use only [A-Za-z0-9_-], 1-256 chars.
# Leave empty to disable the manual trigger and skip webhook header validation.
MANUAL_TRIGGER_TOKEN="some-long-random-string"
